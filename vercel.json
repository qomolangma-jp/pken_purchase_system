{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://komapay.p-kmt.com/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://komapay.p-kmt.com/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/payments/paypay.js": {
      "memory": 128,
      "maxDuration": 30
    }
  }
}