# 本番環境（Vercel）用の設定

# LIFF設定
VITE_LIFF_ID=2008952926-JJklUx0R

# LINE Login設定
VITE_LINE_LOGIN_CHANNEL_ID=2008952926
VITE_LINE_LOGIN_CALLBACK_URL=https://pken-purchase-system.vercel.app/auth/callback

# バックエンドAPI URL
# 本番環境では Vercel の rewrite 機能で /api 経由で komapay.p-kmt.com へ転送される
# 相対URLで空文字列を指定
VITE_API_BASE_URL=

# デバッグログ
VITE_FORCE_DEBUG=true

# デバッグ: LINE LIFF認証をスキップしてモックユーザーで強制ログイン
VITE_DEBUG_MOCK=false
